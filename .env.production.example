# ─────────────────────────────────────────────────────
# CBC Teachers Hub — PRODUCTION Environment Template
# ─────────────────────────────────────────────────────
# Copy all values into Vercel Dashboard → Environment Variables.
# NEVER commit actual secrets to git.
#
# Variables prefixed NEXT_PUBLIC_ are safe in the browser.
# All others are server-only and never exposed to the client.

# ── Firebase Client SDK (required) ──────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cbc-teachers-hub.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cbc-teachers-hub
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cbc-teachers-hub.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=107581347299
NEXT_PUBLIC_FIREBASE_APP_ID=1:107581347299:web:...
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-...

# ── Firebase Admin SDK (server-only, required) ──────
# Paste the entire JSON from your service account key file.
# Example: {"type":"service_account","project_id":"cbc-teachers-hub",...}
FIREBASE_ADMIN_SERVICE_ACCOUNT={"type":"service_account",...}

# ── AI Providers (at least one required) ────────────
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-...

# ── Payments — Pesapal (required for subscriptions) ─
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_ID=
PESAPAL_ENVIRONMENT=production

# ── Cloudinary (optional — image uploads) ───────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email — Resend (optional — password reset) ──────
RESEND_API_KEY=re_...

# ── Analytics (optional) ────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# ── Public URL (required — no default fallback) ─────
# Must be your production URL. NO trailing slash.
NEXT_PUBLIC_BASE_URL=https://cbc-teachers-hub.vercel.app
